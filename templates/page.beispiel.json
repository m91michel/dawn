{
  "sections": {
    "banner": {
      "type": "image-banner",
      "settings": {
        "height": "medium",
        "adapt_height_first_image": false,
        "desktop_text_box_position": "center",
        "color_scheme": "scheme-1",
        "stack_images_on_mobile": true,
        "show_text_box": true,
        "image_overlay_opacity": 0,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "content": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Willkommen auf unserer neuen Seite",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Dies ist eine Beispiel-Seite, die zeigt, wie du verschiedene Sektionen kombinieren kannst. Du kannst hier beliebigen Inhalt hinzufügen und das Layout nach deinen Wünschen anpassen.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Mehr erfahren",
            "button_link": "/pages/contact",
            "button_style_secondary": false
          }
        }
      },
      "block_order": ["heading", "text", "button"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "scheme-1",
        "full_width": true,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "newsletter": {
      "type": "newsletter",
      "settings": {
        "heading": "Newsletter abonnieren",
        "subtext": "Bleibe auf dem Laufenden mit unseren neuesten Angeboten und Updates.",
        "color_scheme": "scheme-1",
        "padding_top": 36,
        "padding_bottom": 36
      }
    }
  },
  "order": ["banner", "content", "newsletter"]
}
